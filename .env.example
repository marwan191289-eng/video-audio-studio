# =============================================================================
# Video Audio Studio — Environment Variables
# =============================================================================
# انسخ هذا الملف إلى .env واملأ القيم المطلوبة
# cp .env.example .env
#
# النظام يعمل بـ Vite. المتغيرات التي تبدأ بـ VITE_ ستكون مرئية من المتصفح،
# لذا لا تضع مفاتيح سرية فيها.

# ── Supabase (لحفظ الفيديوهات والمعالجة السحابية) ─────────────────────────
# مطلوب للمكتبة السحابية والتحسين عبر السيرفر
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── FFmpeg path (اختياري) ─────────────────────────────────────────────────
# إذا لم تجد المكتبة ffmpeg-static المسار تلقائياً
# FFMPEG_PATH=/usr/bin/ffmpeg

# ── Server ──────────────────────────────────────────────────────────────────
# PORT=8080
# NODE_ENV=production